# ── Copy this to .env and fill in your paths ──────────────
# NEVER commit .env to GitHub

# Root xBD dataset directory
# Should contain: tier1/, tier3/, hold/, test/
DATA_DIR=/path/to/xbd

# Cache and output paths
CACHE_DIR=./data/tile_cache
OUTPUT_DIR=./outputs
CHECKPOINT_DIR=./outputs/checkpoints

# WandB
WANDB_PROJECT=xrayearth
WANDB_ENTITY=your_username_here

# Reproducibility
SEED=42
